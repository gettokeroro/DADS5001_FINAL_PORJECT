# Copy this file to `secrets.toml` and fill in your real keys.
# `.streamlit/secrets.toml` is gitignored — never commit secrets.

# ----- LLM provider (Phase 4) -----
# Choose one and uncomment:

# Google Gemini
# GOOGLE_API_KEY = "your-gemini-key-here"

# Anthropic Claude
# ANTHROPIC_API_KEY = "your-claude-key-here"

# OpenAI
# OPENAI_API_KEY = "your-openai-key-here"

# ----- External database (Phase 5) -----
# Supabase
# SUPABASE_URL = "https://xxxxx.supabase.co"
# SUPABASE_KEY = "your-supabase-anon-key"

# ----- App settings -----
# DEBUG = false
# LLM_RATE_LIMIT_PER_DAY = 20
