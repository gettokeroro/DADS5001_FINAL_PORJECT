# =====================================================================
# TEMPLATE ONLY — DO NOT PUT REAL KEYS HERE
# =====================================================================
# This file IS committed to GitHub as documentation.
# Real keys must go in `.streamlit/secrets.toml` (gitignored)
# OR in Streamlit Cloud → Manage app → Settings → Secrets.
#
# Workflow:
#   1. Copy this file to `.streamlit/secrets.toml` (LOCAL ONLY)
#   2. Replace placeholder with real key
#   3. Never commit the .toml file
#   4. For deployed app: paste real keys in Streamlit Cloud Secrets UI
# =====================================================================


# ----- LLM provider (Phase 4) -----
# Pick one and uncomment in your local secrets.toml (NOT here):

# Google Gemini (recommended)
# GOOGLE_API_KEY = "PASTE-YOUR-KEY-HERE"

# Anthropic Claude
# ANTHROPIC_API_KEY = "PASTE-YOUR-KEY-HERE"

# OpenAI
# OPENAI_API_KEY = "PASTE-YOUR-KEY-HERE"


# ----- External database (Phase 5) -----

# Supabase
# SUPABASE_URL = "https://xxxxx.supabase.co"
# SUPABASE_KEY = "PASTE-YOUR-ANON-KEY-HERE"


# ----- App settings -----

# DEBUG = false
# LLM_RATE_LIMIT_PER_DAY = 20
