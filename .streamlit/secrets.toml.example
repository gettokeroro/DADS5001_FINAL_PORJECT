# =====================================================================
# TEMPLATE ONLY — DO NOT PUT REAL KEYS HERE
# =====================================================================
# This file IS committed to GitHub as documentation.
# Real keys must go in `.streamlit/secrets.toml` (gitignored)
# OR in Streamlit Cloud → Manage app → Settings → Secrets.
#
# Workflow:
#   1. Copy this file to `.streamlit/secrets.toml` (LOCAL ONLY)
#   2. Replace placeholder with real key
#   3. Never commit the .toml file
#   4. For deployed app: paste real keys in Streamlit Cloud Secrets UI
# =====================================================================


# ----- LLM provider (Phase 4) -----
# Pick one and uncomment in your local secrets.toml (NOT here):

# Google Gemini (recommended)
# GOOGLE_API_KEY = "PASTE-YOUR-KEY-HERE"

# Anthropic Claude
# ANTHROPIC_API_KEY = "PASTE-YOUR-KEY-HERE"

# OpenAI
# OPENAI_API_KEY = "PASTE-YOUR-KEY-HERE"


# ----- External database (Phase 5) -----

# Supabase
# SUPABASE_URL = "https://xxxxx.supabase.co"
# SUPABASE_KEY = "PASTE-YOUR-ANON-KEY-HERE"


# ----- Snowflake (Phase 9 — Cloud storage for ข้อ 3 spec) -----
# Stores TRAIN_MATRIX (5620x133), DISEASE_DRUG (109), HOSPITALS (1581)
# Account identifier format: org-account (new) — see Snowsight URL
# Workflow: copy this whole block into your local .streamlit/secrets.toml,
# uncomment, and fill in your real values.
#
# [snowflake]
# account   = "xadiaad-hp58814"     # from Snowsight URL: app.snowflake.com/<org>/<account>
# user      = "GETTOKERORO"          # SELECT CURRENT_USER() in Snowsight
# password  = "PASTE-YOUR-PASSWORD"  # your Snowflake login password
# warehouse = "COMPUTE_WH"
# database  = "DADS5001"
# schema    = "TRIAGE"


# ----- MongoDB Atlas (Phase 9b — second cloud per ข้อ 3 spec) -----
# Stores: symptom_dictionary (132 docs) · disease_prevalence (48 docs) · ai_sessions (write log)
# Get URI: Atlas → Cluster0 → Connect → Drivers → Python
#
[mongodb]
uri     = "mongodb+srv://USER:PASS@cluster0.xkwi2nj.mongodb.net/?appName=Cluster0"
db_name = "dads5001"


# ----- App settings -----

# DEBUG = false
# LLM_RATE_LIMIT_PER_DAY = 20
